{
  "recipe_id": "macos.textedit.create_and_verify_text.v0",
  "version": "0.1.0",
  "status": "experimental-recipe",
  "platform": "macOS",
  "target_app": {
    "name": "文本编辑",
    "bundle_id": "${app_id}",
    "display_mode": "live-desktop"
  },
  "strategy": {
    "family": "native-text",
    "grounding": "ax-text",
    "activation": "pointer-focus-clipboard-paste",
    "verificationContract": "verifyAxText"
  },
  "objective": "Focus TextEdit's main text area, write a stable marker, and verify the marker through the AX tree without screenshot OCR.",
  "inputs": {
    "app_id": {
      "type": "string",
      "default": "com.apple.TextEdit"
    },
    "note_body": {
      "type": "string",
      "default": "AUV_TEXTEDIT_MARKER_2026_05_17"
    },
    "activate_settle_ms": {
      "type": "integer",
      "default": 250
    },
    "type_settle_ms": {
      "type": "integer",
      "default": 250
    }
  },
  "preconditions": [
    "The host is macOS.",
    "TextEdit is installed and can be addressed by ${app_id}.",
    "Screen Recording and Accessibility permissions are already granted."
  ],
  "disturbance_policy": {
    "max_disturbance": "pointer",
    "declared_classes": [
      "none",
      "foreground_app",
      "keyboard",
      "clipboard",
      "pointer"
    ],
    "notes": [
      "This recipe foregrounds TextEdit and writes a stable marker into the main text area.",
      "Verification uses AX tree text matching instead of screenshot OCR.",
      "This is a third native-app sample that checks the same contract against a simpler editor surface."
    ]
  },
  "steps": [
    {
      "id": "activate-target-app",
      "command_id": "debug.activateApp",
      "disturbance": {
        "classes": [
          "foreground_app"
        ],
        "max": "foreground_app"
      },
      "args": {
        "target": "${app_id}",
        "settle_ms": "${activate_settle_ms}"
      }
    },
    {
      "id": "focus-body",
      "command_id": "debug.focusTextInput",
      "disturbance": {
        "classes": [
          "foreground_app",
          "keyboard",
          "pointer"
        ],
        "max": "pointer"
      },
      "args": {
        "target": "${app_id}",
        "query": "First Text View",
        "max_depth": 6,
        "max_children": 40
      },
      "expect": {
        "signal_equals": {
          "focusTextInput.consumer": "query"
        }
      },
      "purpose": "Focus the main TextEdit body through AX."
    },
    {
      "id": "paste-body",
      "command_id": "debug.pasteTextPreserveClipboard",
      "disturbance": {
        "classes": [
          "foreground_app",
          "keyboard",
          "clipboard"
        ],
        "max": "clipboard"
      },
      "args": {
        "target": "${app_id}",
        "text": "${note_body}",
        "replace_existing": true,
        "submit_settle_ms": "${type_settle_ms}"
      },
      "purpose": "Write the marker into the TextEdit body through the clipboard."
    },
    {
      "id": "verify-text-marker",
      "command_id": "verify.axText",
      "disturbance": {
        "classes": [
          "none"
        ],
        "max": "none"
      },
      "args": {
        "target": "${app_id}",
        "target_text": "${note_body}",
        "target_role": "AXTextArea",
        "max_depth": 6,
        "max_children": 48
      },
      "expect": {
        "signal_equals": {
          "ax.node_found": "true",
          "ax.matched_role": "AXTextArea"
        },
        "signal_contains": {
          "ax.matched_text": "${note_body}"
        },
        "artifact_count_at_least": 1
      },
      "purpose": "Verify the marker through the AX tree, not screenshot OCR."
    }
  ],
  "verification": {
    "expected_signals": [
      "TextEdit can be activated.",
      "The main text area can be focused through AX.",
      "The marker text can be written into the body.",
      "The same marker can be verified through the AX tree."
    ],
    "success_criteria": [
      "The marker is visible in the AX tree under the TextEdit text area.",
      "The recipe completes without screenshot OCR."
    ],
    "non_goals": [
      "This recipe does not prove browser or music-player reuse.",
      "This recipe does not prove rich formatting manipulation."
    ]
  },
  "known_limits": {
    "narrow_baseline": "This is a minimal editor sample, not a full document editing contract.",
    "shared_app_state": "Do not run concurrently with another TextEdit recipe against the same live app instance."
  }
}
