{
  "recipe_id": "macos.qqmusic.play_search_result_candidate.v0",
  "version": "0.1.0",
  "status": "experimental-recipe",
  "platform": "macOS",
  "target_app": {
    "name": "QQ音乐",
    "bundle_id": "${app_id}",
    "display_mode": "live-desktop"
  },
  "strategy": {
    "family": "playback",
    "grounding": "visual-row",
    "activation": "pointer-row-activation",
    "verificationContract": "verifyNowPlayingTitle"
  },
  "objective": "Reach QQ音乐 search results, materialize a typed candidate set through music.search.results, then consume the selected CandidateRef through music.result.play and verify the resulting now-playing title.",
  "inputs": {
    "app_id": {
      "type": "string",
      "default": "com.tencent.QQMusicMac"
    },
    "query": {
      "type": "string",
      "default": "aa",
      "note": "Current fallback baseline starts from the ASCII query aa."
    },
    "target_title": {
      "type": "string",
      "default": "Cure For Me - AURORA",
      "note": "The expected now-playing title that must be verified through the AX tree after candidate activation."
    },
    "target_artist": {
      "type": "string",
      "default": ""
    },
    "reveal_shortcut": {
      "type": "string",
      "default": "cmd+f"
    },
    "reveal_settle_ms": {
      "type": "integer",
      "default": 300
    },
    "submit_settle_ms": {
      "type": "integer",
      "default": 900
    },
    "dismiss_overlay_key": {
      "type": "string",
      "default": "escape"
    },
    "dismiss_overlay_settle_ms": {
      "type": "integer",
      "default": 300
    },
    "result_region_left_ratio": {
      "type": "number",
      "default": 0.14
    },
    "result_region_top_ratio": {
      "type": "number",
      "default": 0.34
    },
    "result_region_right_ratio": {
      "type": "number",
      "default": 0.90
    },
    "result_region_bottom_ratio": {
      "type": "number",
      "default": 0.95
    },
    "row_min_confidence": {
      "type": "number",
      "default": 0.90
    },
    "row_max_observations": {
      "type": "integer",
      "default": 128
    },
    "row_wait_min_row_count": {
      "type": "integer",
      "default": 3
    },
    "row_wait_timeout_ms": {
      "type": "integer",
      "default": 3500
    },
    "row_wait_poll_ms": {
      "type": "integer",
      "default": 250
    },
    "row_index": {
      "type": "integer",
      "default": 2,
      "note": "1-based visible result row used to select the candidate handle. This is still a row-order baseline, not a semantic title selector."
    },
    "play_button_query": {
      "type": "string",
      "default": "播放"
    },
    "play_button_region_left_ratio": {
      "type": "number",
      "default": 0.18
    },
    "play_button_region_top_ratio": {
      "type": "number",
      "default": 0.28
    },
    "play_button_region_right_ratio": {
      "type": "number",
      "default": 0.60
    },
    "play_button_region_bottom_ratio": {
      "type": "number",
      "default": 0.42
    },
    "play_button_min_confidence": {
      "type": "number",
      "default": 0.75
    },
    "play_button_overlay_label": {
      "type": "string",
      "default": "auv · play"
    },
    "activation_settle_ms": {
      "type": "integer",
      "default": 900
    },
    "click_count": {
      "type": "integer",
      "default": 2
    },
    "row_anchor_mode": {
      "type": "string",
      "default": "title_band"
    },
    "row_anchor_x_ratio": {
      "type": "number",
      "default": 0.25
    },
    "row_anchor_y_ratio": {
      "type": "number",
      "default": 0.50
    },
    "now_playing_scope_path_prefix": {
      "type": "string",
      "default": "0.4.4"
    }
  },
  "preconditions": [
    "The host is macOS.",
    "QQ音乐 is installed and can be addressed by ${app_id}.",
    "Screen Recording and Accessibility permissions are already granted.",
    "The search result surface must still be visible when music.search.results captures the candidate set.",
    "The selected candidate is still chosen by current visible row index, not by semantic title disambiguation."
  ],
  "disturbance_policy": {
    "max_disturbance": "pointer",
    "declared_classes": [
      "none",
      "foreground_app",
      "keyboard",
      "clipboard",
      "pointer"
    ],
    "notes": [
      "Search entry still foregrounds QQ音乐 and uses the clipboard for query submission.",
      "music.search.results is observation-only and emits a typed OperationResult plus CandidateRef signals.",
      "music.result.play consumes the selected CandidateRef but still re-activates the visible row through pointer disturbance before pressing the play control."
    ]
  },
  "steps": [
    {
      "id": "open-search",
      "command_id": "debug.pressKey",
      "disturbance": {
        "classes": ["foreground_app", "keyboard"],
        "max": "keyboard"
      },
      "args": {
        "target": "${app_id}",
        "key": "${reveal_shortcut}",
        "settle_ms": "${reveal_settle_ms}"
      }
    },
    {
      "id": "paste-query",
      "command_id": "debug.pasteTextPreserveClipboard",
      "disturbance": {
        "classes": ["foreground_app", "keyboard", "clipboard"],
        "max": "clipboard"
      },
      "args": {
        "target": "${app_id}",
        "text": "${query}",
        "replace_existing": true,
        "submit_key": "return",
        "submit_settle_ms": "${submit_settle_ms}"
      }
    },
    {
      "id": "dismiss-search-overlay",
      "command_id": "debug.pressKey",
      "disturbance": {
        "classes": ["foreground_app", "keyboard"],
        "max": "keyboard"
      },
      "args": {
        "target": "${app_id}",
        "key": "${dismiss_overlay_key}",
        "settle_ms": "${dismiss_overlay_settle_ms}"
      }
    },
    {
      "id": "wait-for-screen-rows",
      "command_id": "debug.waitForScreenRows",
      "disturbance": {
        "classes": ["foreground_app"],
        "max": "foreground_app"
      },
      "args": {
        "target": "${app_id}",
        "min_row_count": "${row_wait_min_row_count}",
        "timeout_ms": "${row_wait_timeout_ms}",
        "poll_interval_ms": "${row_wait_poll_ms}",
        "max_observations": "${row_max_observations}",
        "min_confidence": "${row_min_confidence}",
        "region_left_ratio": "${result_region_left_ratio}",
        "region_top_ratio": "${result_region_top_ratio}",
        "region_right_ratio": "${result_region_right_ratio}",
        "region_bottom_ratio": "${result_region_bottom_ratio}",
        "activate_target_before_capture": true
      },
      "expect": {
        "signal_equals": {
          "rows.requirement_met": "true",
          "rows.timed_out": "false"
        }
      }
    },
    {
      "id": "search-results",
      "command_id": "music.search.results",
      "disturbance": {
        "classes": ["none"],
        "max": "none"
      },
      "args": {
        "target": "${app_id}",
        "selected_row_index": "${row_index}",
        "max_observations": "${row_max_observations}",
        "min_confidence": "${row_min_confidence}",
        "region_left_ratio": "${result_region_left_ratio}",
        "region_top_ratio": "${result_region_top_ratio}",
        "region_right_ratio": "${result_region_right_ratio}",
        "region_bottom_ratio": "${result_region_bottom_ratio}"
      },
      "expect": {
        "signal_equals": {
          "rows.visible": "true",
          "music.search.results.selected_candidate_resolved": "true"
        }
      }
    },
    {
      "id": "play-candidate",
      "command_id": "music.result.play",
      "disturbance": {
        "classes": ["foreground_app", "pointer"],
        "max": "pointer"
      },
      "args": {
        "target": "${app_id}",
        "candidate_ref": "${step_search_results_signal_music_search_results_selected_candidate_ref}",
        "target_title": "${target_title}",
        "target_artist": "${target_artist}",
        "play_button_query": "${play_button_query}",
        "play_button_region_left_ratio": "${play_button_region_left_ratio}",
        "play_button_region_top_ratio": "${play_button_region_top_ratio}",
        "play_button_region_right_ratio": "${play_button_region_right_ratio}",
        "play_button_region_bottom_ratio": "${play_button_region_bottom_ratio}",
        "play_button_min_confidence": "${play_button_min_confidence}",
        "play_button_overlay_label": "${play_button_overlay_label}",
        "activation_settle_ms": "${activation_settle_ms}",
        "click_count": "${click_count}",
        "row_min_confidence": "${row_min_confidence}",
        "row_max_observations": "${row_max_observations}",
        "row_anchor_mode": "${row_anchor_mode}",
        "row_anchor_x_ratio": "${row_anchor_x_ratio}",
        "row_anchor_y_ratio": "${row_anchor_y_ratio}",
        "now_playing_scope_path_prefix": "${now_playing_scope_path_prefix}"
      },
      "mainline_exemption": {
        "reason": "Structured-candidate consumer pass for QQ音乐. This recipe exists to prove the producer->CandidateRef->consumer chain in a real product slice before broader generalization.",
        "category": "experiment"
      },
      "expect": {
        "signal_equals": {
          "music.result.play.resolved": "true",
          "music.result.semantic_matched": "true",
          "candidate.input_mode": "candidate_ref",
          "music.result.consumed_candidate_source_operation_id": "music.search.results",
          "music.result.consumed_candidate_local_id": "${step_search_results_signal_music_search_results_selected_candidate_local_id}"
        },
        "artifact_count_at_least": 1
      }
    }
  ],
  "verification": {
    "expected_signals": [
      "debug.waitForScreenRows reports enough visible rows in the constrained result region.",
      "music.search.results emits a typed OperationResult and resolves selected_candidate_ref for the requested row index.",
      "music.result.play consumes that candidate_ref, re-checks liveness, re-activates the row, and verifies ${target_title} through the AX now-playing contract."
    ],
    "success_criteria": [
      "A typed CandidateRef is selected from the observed result set.",
      "The selected CandidateRef is consumed by music.result.play.",
      "The current now-playing title is verified through the AX tree."
    ],
    "non_goals": [
      "This recipe does not prove semantic title disambiguation inside the result list.",
      "This recipe does not prove generalized playback for arbitrary queries.",
      "This recipe does not make playback activation pointer-free."
    ]
  },
  "known_limits": {
    "row_index_selection": "Candidate selection is still based on current visible row order. If the result list scrolls or reorders between music.search.results and music.result.play, the selected candidate may drift.",
    "qqmusic_webview": "QQ音乐 result rows still ground through OCR/visual-row evidence because the WebView content is not exposed as stable AX list rows.",
    "semantic_selection": "A typed CandidateRef does not itself prove semantic correctness; the current baseline still depends on the caller choosing the right visible row index.",
    "shared_app_state": "Do not run multiple QQ音乐 recipes against the same live app instance at once."
  }
}
