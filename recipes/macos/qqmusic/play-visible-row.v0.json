{
  "recipe_id": "macos.qqmusic.play_visible_row.v0",
  "version": "0.1.0",
  "status": "experimental-recipe",
  "platform": "macOS",
  "target_app": {
    "name": "QQ音乐",
    "bundle_id": "${app_id}",
    "display_mode": "live-desktop"
  },
  "objective": "Reach QQ音乐 search results, activate a visible result row through row detection, press the result play control, and verify the resulting now-playing title from the captured evidence image.",
  "inputs": {
    "app_id": {
      "type": "string",
      "default": "com.tencent.QQMusicMac"
    },
    "query": {
      "type": "string",
      "default": "aa",
      "note": "Current fallback baseline starts from the ASCII query aa."
    },
    "playback_title": {
      "type": "string",
      "default": "Cure For Me - AURORA",
      "note": "The expected bottom-player title OCR string after row activation."
    },
    "reveal_shortcut": {
      "type": "string",
      "default": "cmd+f"
    },
    "reveal_settle_ms": {
      "type": "integer",
      "default": 300
    },
    "submit_settle_ms": {
      "type": "integer",
      "default": 900
    },
    "dismiss_overlay_key": {
      "type": "string",
      "default": "escape"
    },
    "dismiss_overlay_settle_ms": {
      "type": "integer",
      "default": 300
    },
    "result_region_left_ratio": {
      "type": "number",
      "default": 0.14
    },
    "result_region_top_ratio": {
      "type": "number",
      "default": 0.34
    },
    "result_region_right_ratio": {
      "type": "number",
      "default": 0.90
    },
    "result_region_bottom_ratio": {
      "type": "number",
      "default": 0.95
    },
    "row_min_confidence": {
      "type": "number",
      "default": 0.90
    },
    "row_max_observations": {
      "type": "integer",
      "default": 128
    },
    "row_wait_min_row_count": {
      "type": "integer",
      "default": 3,
      "note": "Wait until at least this many visible rows appear before row activation."
    },
    "row_wait_timeout_ms": {
      "type": "integer",
      "default": 3500
    },
    "row_wait_poll_ms": {
      "type": "integer",
      "default": 250
    },
    "row_index": {
      "type": "integer",
      "default": 2,
      "note": "1-based index of the visible result row to activate. The current canonical fallback baseline uses 2 in the current QQ音乐 layout."
    },
    "row_anchor_mode": {
      "type": "string",
      "default": "title_band"
    },
    "row_anchor_x_ratio": {
      "type": "number",
      "default": 0.25
    },
    "row_anchor_y_ratio": {
      "type": "number",
      "default": 0.50
    },
    "click_count": {
      "type": "integer",
      "default": 2,
      "note": "The first validated activation path is a row double-click."
    },
    "play_button_query": {
      "type": "string",
      "default": "播放"
    },
    "play_button_max_depth": {
      "type": "integer",
      "default": 8
    },
    "play_button_max_children": {
      "type": "integer",
      "default": 20
    },
    "activation_settle_ms": {
      "type": "integer",
      "default": 900,
      "note": "How long to wait after row activation before capturing evidence."
    },
    "verification_region_left_ratio": {
      "type": "number",
      "default": 0.22
    },
    "verification_region_top_ratio": {
      "type": "number",
      "default": 0.80
    },
    "verification_region_right_ratio": {
      "type": "number",
      "default": 0.45
    },
    "verification_region_bottom_ratio": {
      "type": "number",
      "default": 0.90
    },
    "verification_min_confidence": {
      "type": "number",
      "default": 0.90
    }
  },
  "preconditions": [
    "The host is macOS.",
    "QQ音乐 is installed and can be addressed by ${app_id}.",
    "Screen Recording and Accessibility permissions are already granted.",
    "The recipe runs on the live desktop, re-activates QQ音乐 before live capture steps, and still uses pointer disturbance for activation."
  ],
  "disturbance_policy": {
    "max_disturbance": "pointer",
    "declared_classes": [
      "none",
      "foreground_app",
      "keyboard",
      "clipboard",
      "pointer"
    ],
    "notes": [
      "This recipe is not non-disturbing. It foregrounds QQ音乐, re-activates QQ音乐 before live capture steps, uses the clipboard during search entry, and uses pointer disturbance for row activation.",
      "The row-detection and playback-verification steps are observation-only because they run OCR against captured screenshots instead of recapturing the live desktop.",
      "This is a narrow experimental playback fallback, not a general qqmusic.play_song contract."
    ]
  },
  "steps": [
    {
      "id": "open-search",
      "command_id": "debug.pressKey",
      "disturbance": {
        "classes": [
          "foreground_app",
          "keyboard"
        ],
        "max": "keyboard"
      },
      "args": {
        "target": "${app_id}",
        "key": "${reveal_shortcut}",
        "settle_ms": "${reveal_settle_ms}"
      }
    },
    {
      "id": "paste-query",
      "command_id": "debug.pasteTextPreserveClipboard",
      "disturbance": {
        "classes": [
          "foreground_app",
          "keyboard",
          "clipboard"
        ],
        "max": "clipboard"
      },
      "args": {
        "target": "${app_id}",
        "text": "${query}",
        "replace_existing": true,
        "submit_key": "return",
        "submit_settle_ms": "${submit_settle_ms}"
      }
    },
    {
      "id": "dismiss-search-overlay",
      "command_id": "debug.pressKey",
      "disturbance": {
        "classes": [
          "foreground_app",
          "keyboard"
        ],
        "max": "keyboard"
      },
      "args": {
        "target": "${app_id}",
        "key": "${dismiss_overlay_key}",
        "settle_ms": "${dismiss_overlay_settle_ms}"
      }
    },
    {
      "id": "wait-for-screen-rows",
      "command_id": "debug.waitForScreenRows",
      "disturbance": {
        "classes": [
          "none"
        ],
        "max": "none"
      },
      "args": {
        "target": "${app_id}",
        "min_row_count": "${row_wait_min_row_count}",
        "timeout_ms": "${row_wait_timeout_ms}",
        "poll_interval_ms": "${row_wait_poll_ms}",
        "max_observations": "${row_max_observations}",
        "min_confidence": "${row_min_confidence}",
        "region_left_ratio": "${result_region_left_ratio}",
        "region_top_ratio": "${result_region_top_ratio}",
        "region_right_ratio": "${result_region_right_ratio}",
        "region_bottom_ratio": "${result_region_bottom_ratio}",
        "activate_target_before_capture": true
      },
      "expect": {
        "output_must_not_contain": [
          "Timed out while polling"
        ]
      }
    },
    {
      "id": "click-visible-row",
      "command_id": "debug.clickScreenRow",
      "disturbance": {
        "classes": [
          "pointer"
        ],
        "max": "pointer"
      },
      "args": {
        "target": "${app_id}",
        "row_index": "${row_index}",
        "click_count": "${click_count}",
        "settle_ms": "${activation_settle_ms}",
        "row_anchor_mode": "${row_anchor_mode}",
        "row_anchor_x_ratio": "${row_anchor_x_ratio}",
        "row_anchor_y_ratio": "${row_anchor_y_ratio}",
        "max_observations": "${row_max_observations}",
        "min_confidence": "${row_min_confidence}",
        "region_left_ratio": "${result_region_left_ratio}",
        "region_top_ratio": "${result_region_top_ratio}",
        "region_right_ratio": "${result_region_right_ratio}",
        "region_bottom_ratio": "${result_region_bottom_ratio}",
        "activate_target_before_capture": true
      },
      "expect": {
        "output_must_not_contain": [
          "no visible row at index"
        ]
      }
    },
    {
      "id": "press-result-play",
      "command_id": "debug.pressButton",
      "disturbance": {
        "classes": [
          "foreground_app",
          "keyboard",
          "pointer"
        ],
        "max": "pointer"
      },
      "args": {
        "target": "${app_id}",
        "query": "${play_button_query}",
        "max_depth": "${play_button_max_depth}",
        "max_children": "${play_button_max_children}"
      },
      "expect": {
        "output_must_not_contain": [
          "no matching"
        ]
      }
    },
    {
      "id": "capture-evidence",
      "command_id": "debug.captureScreen",
      "disturbance": {
        "classes": [
          "none"
        ],
        "max": "none"
      },
      "args": {
        "target": "${app_id}",
        "label": "qqmusic-row-playback-${query}",
        "activate_target_before_capture": true
      },
      "expect": {
        "artifact_count_at_least": 1
      }
    },
    {
      "id": "verify-player-title",
      "command_id": "debug.findImageText",
      "disturbance": {
        "classes": [
          "none"
        ],
        "max": "none"
      },
      "args": {
        "image_path": "${step_capture_evidence_artifact_image_0}",
        "query": "${playback_title}",
        "min_confidence": "${verification_min_confidence}",
        "region_left_ratio": "${verification_region_left_ratio}",
        "region_top_ratio": "${verification_region_top_ratio}",
        "region_right_ratio": "${verification_region_right_ratio}",
        "region_bottom_ratio": "${verification_region_bottom_ratio}"
      },
      "expect": {
        "output_must_contain": [
          "${playback_title}"
        ],
        "output_must_not_contain": [
          "Found 0 OCR text matches"
        ]
      }
    }
  ],
  "verification": {
    "expected_signals": [
      "The query is submitted through clipboard-backed search entry.",
      "debug.waitForScreenRows reports enough visible rows in the constrained result region.",
      "debug.clickScreenRow reports row bounds and a projected logical click point.",
      "debug.pressButton completes for the result play control.",
      "A captured post-click screenshot artifact exists.",
      "debug.findImageText confirms ${playback_title} inside the bottom-player title region of the captured evidence image."
    ],
    "success_criteria": [
      "A visible row is activated through row detection.",
      "The result play control is pressed.",
      "A captured evidence image exists.",
      "The evidence image contains the expected now-playing title."
    ],
    "non_goals": [
      "This recipe does not prove generalized playback for arbitrary queries.",
      "This recipe does not prove OCR row anchor stability.",
      "This recipe does not prove pointer-free playback activation.",
      "This recipe does not prove that row selection alone starts playback."
    ]
  },
  "known_limits": {
    "narrow_baseline": "This recipe is validated only as a narrow fallback slice and should not yet be advertised as a broad QQ音乐 playback skill.",
    "row_detection": "Result activation depends on row detection plus pointer disturbance through the projected row anchor and a follow-up play control press.",
    "foreground_capture": "Live capture steps explicitly re-activate QQ音乐 before taking screenshots so foreground drift does not contaminate evidence.",
    "captured_image_verification": "Playback verification currently trusts OCR over the captured evidence image, not live-screen OCR.",
    "shared_app_state": "Do not run multiple QQ音乐 recipes against the same live app instance at once."
  }
}
