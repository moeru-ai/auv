{
  "name": "@auv/alint-config",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@alint-js/agent-apeira": "^0.0.33",
    "@alint-js/plugin": "^0.0.33",
    "@alint-js/tools-fs": "^0.0.33"
  }
}
