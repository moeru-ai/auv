{
  "name": "@auv/alint-config",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@alint-js/core": "0.0.20"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.3",
    "typescript": "^5.9.3"
  }
}
